{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": [
    ".nelle/**",
    "apps/client/**",
    "build/**",
    "coverage/**",
    "dist/**",
    "node_modules/**"
  ],
  "plugins": ["import", "node", "promise"],
  "rules": {
    "import/no-unassigned-import": "off",
    "no-await-in-loop": "off",
    "no-unmodified-loop-condition": "off",
    "no-unused-vars": "error"
  }
}
