{
  "name": "nelle-server",
  "version": "1.0.0",
  "description": "Local-first server for Nelle Agent.",
  "type": "module",
  "main": "apps/server/src/index.ts",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "astryx": "bun node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "dev": "concurrently -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start": "bun apps/server/src/index.ts --open",
    "serve": "bun apps/server/src/index.ts",
    "serve:e2e": "bun scripts/serve-e2e.ts",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "tsc --noEmit",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:binary": "bun build --compile apps/server/src/index.ts --outfile dist/nelle-server",
    "build:openapi": "bun scripts/build-openapi.ts",
    "build": "bun run check && bun run build:web",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test": "bun run format:check && bun run lint && bun run test:unit && bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenanQueiroz/nelle-agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RenanQueiroz/nelle-agent/issues"
  },
  "homepage": "https://github.com/RenanQueiroz/nelle-agent#readme",
  "dependencies": {
    "@astryxdesign/cli": "^0.1.4",
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@heroicons/react": "^2.2.0",
    "@huggingface/gguf": "^0.4.2",
    "@napi-rs/canvas": "^1.0.2",
    "@tanstack/react-virtual": "^3.14.5",
    "fflate": "^0.8.3",
    "node-forge": "^1.4.0",
    "open": "^11.0.0",
    "pdfjs-dist": "^6.1.200",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
