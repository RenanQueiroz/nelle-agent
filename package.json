{
  "name": "nelle-server",
  "version": "1.0.0",
  "description": "Local-first server for Nelle Agent.",
  "type": "module",
  "main": "apps/server/src/index.ts",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:binary": "bun build --compile apps/server/src/index.ts --outfile dist/nelle-server",
    "build:openapi": "bun scripts/build-openapi.ts && oxfmt openapi.json",
    "check": "tsc --noEmit",
    "dev": "bun --watch apps/server/src/index.ts",
    "dev:all": "bun run scripts/dev.ts",
    "doctor": "bun run scripts/doctor.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "hooks": "bun run scripts/hooks.ts",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "serve": "bun apps/server/src/index.ts",
    "setup": "bun run scripts/setup.ts",
    "test": "bun run format:check && bun run lint && bun run check && bun run test:unit",
    "test:device": "bun run scripts/test-device.ts",
    "test:device:slow": "bun run scripts/test-device.ts --slow",
    "test:unit": "bun test tests/unit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenanQueiroz/nelle-agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/RenanQueiroz/nelle-agent/issues"
  },
  "homepage": "https://github.com/RenanQueiroz/nelle-agent#readme",
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@huggingface/gguf": "^0.4.2",
    "@napi-rs/canvas": "^1.0.2",
    "fflate": "^0.8.3",
    "node-forge": "^1.4.0",
    "pdfjs-dist": "^6.1.200",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/node-forge": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  }
}
