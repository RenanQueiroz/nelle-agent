{
  "name": "nelle-server",
  "version": "1.0.0",
  "description": "Local-first server for Nelle Agent.",
  "type": "module",
  "main": "apps/server/src/index.ts",
  "scripts": {
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start": "tsx apps/server/src/index.ts --open",
    "serve": "tsx apps/server/src/index.ts",
    "serve:e2e": "tsx scripts/serve-e2e.ts",
    "check": "tsc --noEmit",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run check && npm run build:web",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenanQueiroz/nelle-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RenanQueiroz/nelle-server/issues"
  },
  "homepage": "https://github.com/RenanQueiroz/nelle-server#readme",
  "dependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@heroicons/react": "^2.2.0",
    "fastify": "^5.10.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
