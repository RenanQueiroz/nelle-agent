{
  "name": "nelle-server",
  "version": "1.0.0",
  "description": "Local-first server for Nelle Agent.",
  "type": "module",
  "main": "apps/server/src/index.ts",
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "scripts": {
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start": "tsx apps/server/src/index.ts --open",
    "serve": "tsx apps/server/src/index.ts",
    "serve:e2e": "tsx scripts/serve-e2e.ts",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "tsc --noEmit",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run check && npm run build:web",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test": "npm run format:check && npm run lint && npm run test:unit && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenanQueiroz/nelle-agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RenanQueiroz/nelle-agent/issues"
  },
  "homepage": "https://github.com/RenanQueiroz/nelle-agent#readme",
  "dependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@heroicons/react": "^2.2.0",
    "@huggingface/gguf": "^0.4.2",
    "@napi-rs/canvas": "^1.0.2",
    "@tanstack/react-virtual": "^3.14.5",
    "fastify": "^5.10.0",
    "fflate": "^0.8.3",
    "open": "^11.0.0",
    "pdfjs-dist": "^6.1.200",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
