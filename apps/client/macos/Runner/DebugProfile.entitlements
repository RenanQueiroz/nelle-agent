<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!--
	  `network.server` is Flutter's default: it lets the Dart VM service listen, so a debugger (and
	  Marionette) can attach.

	  `network.client` is NOT in Flutter's default template, and Nelle cannot work without it: it is
	  a *client*, and the App Sandbox blocks every outbound connection. Without it the app launches
	  and then fails every request with `SocketException: ... Operation not permitted`. See
	  `Release.entitlements` -- the release build was missing network access entirely.
	-->
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!--
	  REQUIRED for the attach / import / export file dialogs. Under the App Sandbox, the open/save
	  panels (`NSOpenPanel`/`NSSavePanel`, which `file_selector` drives) run in Apple's out-of-process
	  powerbox, and it grants access to the chosen file ONLY when this entitlement is present. Without
	  it every picker silently no-ops -- clicking Attach/Import/Export does nothing at all, with no
	  error -- which is exactly how it was found. `read-write`, not `read-only`, because Export
	  (`getSaveLocation`) writes the archive the user picks; the plugin's own example ships the same.
	-->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
