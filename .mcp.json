{
  "mcpServers": {
    "marionette": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "export PATH=\"$HOME/.pub-cache/bin:$HOME/development/flutter/bin:$PATH\"; exec marionette_mcp"
      ],
      "env": {}
    },
    "dart": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "export PATH=\"$HOME/development/flutter/bin:$PATH\"; exec dart mcp-server"
      ],
      "env": {}
    }
  }
}
